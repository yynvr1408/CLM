# CLM Platform - Environment Configuration Template
# Copy this to .env and fill in your values

# =========================================
# DATABASE CONNECTION (CRITICAL)
# =========================================
# LOCAL SETUP: Use localhost
# DATABASE_URL="postgresql://clm_user:clm_password@localhost:5432/clm_db"

DATABASE_URL="postgresql://clm_user:clm_password@localhost:5432/clm_db"

# =========================================
# APPLICATION SETTINGS
# =========================================
PROJECT_NAME="CLM Platform"
DEBUG=True
API_V1_STR="/api/v1"

# =========================================
# JWT & SECURITY (IMPORTANT)
# =========================================
# Generate a random 32-char key:
# Linux/Mac: openssl rand -hex 32
# Windows: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-super-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================================
# EMAIL CONFIGURATION (OPTIONAL)
# For Gmail: Get app-specific password
# Visit: https://myaccount.google.com/apppasswords
# =========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAILS_FROM_EMAIL="your-email@gmail.com"

# =========================================
# CORS - ALLOW FRONTEND TO CALL BACKEND
# =========================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# =========================================
# WEBHOOK (OPTIONAL)
# =========================================
WEBHOOK_SECRET="your-webhook-secret-key"

# =========================================
# FRONTEND CONFIGURATION
# =========================================
VITE_API_URL="http://localhost:8000/api/v1"
